<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" version="2.5" method="upgrade" group="hikashoppayment">
	<name>HikaShop Monero (xmr-pay) Payment Plugin</name>
	<creationDate>June 2026</creationDate>
	<version>1.0.5</version>
	<author>SlowBearDigger</author>
	<authorEmail>slowbeardigger@proton.me</authorEmail>
	<authorUrl>https://github.com/SlowBearDigger</authorUrl>
	<copyright>(C) 2026 SlowBearDigger. MIT licensed.</copyright>
	<license>https://opensource.org/licenses/MIT MIT</license>
	<description>Non-custodial Monero payments for HikaShop. View key only — no wallet-rpc, no daemon; funds go straight to the merchant's wallet.</description>
	<install>
		<sql>
			<file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
		</sql>
	</install>
	<uninstall>
		<sql>
			<file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
		</sql>
	</uninstall>
	<files>
		<filename plugin="xmrpay">xmrpay.php</filename>
		<filename>xmrpay_end.php</filename>
		<filename>HikashopOrderStore.php</filename>
		<filename>qrcode.min.js</filename>
		<filename>index.html</filename>
		<folder>engine</folder>
		<folder>sql</folder>
		<folder>views</folder>
		<folder>language</folder>
	</files>
	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.plg_hikashoppayment_xmrpay.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_hikashoppayment_xmrpay.sys.ini</language>
	</languages>
	<params addpath="/components/com_hikashop/params">
		<param name="pluginoptions" type="pluginoptions" default="plugin" label="hikashop" description="HikaShop options" />
	</params>
	<config>
		<fields name="params" addfieldpath="/components/com_hikashop/fields">
			<fieldset name="basic">
				<field id="pluginoptions" name="pluginoptions" type="pluginoptions" label="hikashop" description="HikaShop options" />
			</fieldset>
		</fields>
	</config>
</extension>
